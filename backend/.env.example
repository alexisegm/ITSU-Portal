# Ejemplo de archivo .env para backend (NO subir a repositorio público)
# Copia este archivo a `.env` y reemplaza los valores por los reales.

# URI de conexión a MongoDB Atlas (sin el nombre de la BD al final)
# Ejemplo: mongodb+srv://<user>:<password>@cluster0.qs7xjjv.mongodb.net
MONGO_URI=

# Clave secreta para firmar cookies/ sesiones
SECRET_KEY=

# Credenciales del administrador (evita dejar las por defecto en producción)
ADMIN_EMAIL=admin@itsu.education
ADMIN_PASSWORD=admin

# Contraseña por defecto para estudiantes creados por el admin (opcional)
DEFAULT_STUDENT_PASSWORD=itsu2026

# Configuración de ejecución local
FLASK_DEBUG=True
PORT=5000
